# Gatepath Realtors — Local Development Secrets
# Copy this to .dev.vars and fill in your real values.
# NEVER commit .dev.vars to Git.

# Supabase (get from: https://app.supabase.com → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Paystack (get from: https://dashboard.paystack.com → Settings → API Keys)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# When going live, replace pk_test_ with pk_live_ (public key only — NEVER put sk_live_ here)
